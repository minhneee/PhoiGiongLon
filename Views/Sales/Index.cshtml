@model IEnumerable<SwineBreedingManager.Models.SaleRecord>

@{
    ViewData["Title"] = "Lịch Sử Bán Heo";
}

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title"><i class="fas fa-hand-holding-usd me-3"></i>Lịch Sử Bán Heo</h1>
        <a asp-action="Create" class="btn-premium">
            <i class="fas fa-plus me-2"></i>Ghi Nhận Bán Mới
        </a>
    </div>

    <div class="glass-card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Ngày Bán</th>
                            <th>Số Tai</th>
                            <th>Cân Nặng (kg)</th>
                            <th>Giá Bán (VNĐ)</th>
                            <th>Khách Hàng</th>
                            <th>Ghi Chú</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.SaleDate.ToString("dd/MM/yyyy")</td>
                                <td class="fw-bold text-info">@item.Pig?.TagNumber</td>
                                <td>@item.Weight.ToString("N1") kg</td>
                                <td class="text-success fw-bold">@item.Price.ToString("N0") đ</td>
                                <td>@(item.CustomerName ?? "---")</td>
                                <td class="small">@item.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
