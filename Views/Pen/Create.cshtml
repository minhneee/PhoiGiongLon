@model SwineBreedingManager.Models.Pen

@{
    ViewData["Title"] = "Thêm Chuồng Mới";
}

<div class="container pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title"><i class="fas fa-plus-square me-3"></i>Thêm Chuồng Trại Mới</h1>
        <a asp-action="Index" class="btn btn-outline-light"><i class="fas fa-arrow-left me-2"></i>Quay Lại Sơ Đồ</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="glass-card shadow">
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">Tên / Ký hiệu chuồng <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Ví dụ: Lô A - Chuồng 01" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Capacity" class="form-label fw-bold">Sức chứa tối đa (số con) <span class="text-danger">*</span></label>
                            <input asp-for="Capacity" class="form-control form-control-lg text-center" type="number" min="1" value="10" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả / Phân loại</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Ví dụ: Chuồng tập ăn cho heo con, Chuồng nái đẻ..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="mt-5">
                            <button type="submit" class="btn-premium w-100 py-3">
                                <i class="fas fa-save me-2"></i>Lưu Chuồng Mới
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
