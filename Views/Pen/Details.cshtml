@model SwineBreedingManager.Models.Pen

@{
    ViewData["Title"] = "Chi Tiết Chuồng: " + Model.Name;
}

<div class="container pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title"><i class="fas fa-info-circle me-3"></i>@Model.Name</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning me-2"><i class="fas fa-edit me-2"></i>Sửa Thông Tin</a>
            <a asp-action="Index" class="btn btn-outline-light"><i class="fas fa-arrow-left me-2"></i>Quay Lại Sơ Đồ</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="glass-card shadow h-100">
                <div class="card-header bg-transparent border-bottom border-secondary p-4">
                    <h3 class="mb-0 text-info fw-bold"><i class="fas fa-clipboard-list me-2"></i>Thông Tin Chung</h3>
                </div>
                <div class="card-body p-4 text-light">
                    <div class="mb-4">
                        <label class="text-uppercase small text-muted fw-bold d-block mb-1">Tên Chuồng</label>
                        <h4 class="fw-bold">@Model.Name</h4>
                    </div>
                    
                    <div class="mb-4">
                        <label class="text-uppercase small text-muted fw-bold d-block mb-1">Hiện Trạng Sức Chứa</label>
                        <div class="d-flex align-items-baseline">
                            <h2 class="mb-0 fw-bold text-light me-1">@(Model.Pigs?.Count ?? 0)</h2>
                            <span class="text-light opacity-50 fw-bold">/ @Model.Capacity heo</span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="text-uppercase small text-muted fw-bold d-block mb-1">Mô tả</label>
                        <p class="mb-0 opacity-75">@(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="glass-card shadow h-100">
                <div class="card-header bg-transparent border-bottom border-secondary p-4">
                    <h3 class="mb-0 text-info fw-bold"><i class="fas fa-piggy-bank me-2"></i>Danh Sách Heo Trong Chuồng</h3>
                </div>
                <div class="card-body p-4">
                    @if (Model.Pigs != null && Model.Pigs.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-borderless align-middle text-light mb-0">
                                <thead style="border-bottom: 2px solid rgba(255,255,255,0.1);">
                                    <tr>
                                        <th>Số Tai</th>
                                        <th>Giới Tính</th>
                                        <th>Giống</th>
                                        <th>Trạng Thái</th>
                                        <th>Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pig in Model.Pigs)
                                    {
                                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                            <td class="fw-bold"><i class="fas fa-tag me-2 text-info"></i>@pig.TagNumber</td>
                                            <td>
                                                @if (pig.Gender == SwineBreedingManager.Models.PigGender.Boar)
                                                {
                                                    <span class="badge bg-primary px-3 py-2"><i class="fas fa-mars me-1"></i>Đực</span>
                                                }
                                                else
                                                {
                                                    <span class="badge" style="background-color: #e91e63; padding: 0.5rem 1rem;"><i class="fas fa-venus me-1"></i>Nái</span>
                                                }
                                            </td>
                                            <td>@(pig.Breed ?? "-")</td>
                                            <td>
                                                @switch (pig.Status)
                                                {
                                                    case SwineBreedingManager.Models.PigStatus.Active:
                                                        <span class="badge rounded-pill bg-success px-3">Đang nuôi</span>
                                                        break;
                                                    case SwineBreedingManager.Models.PigStatus.Sold:
                                                        <span class="badge rounded-pill bg-info px-3">Đã bán</span>
                                                        break;
                                                    case SwineBreedingManager.Models.PigStatus.Slaughtered:
                                                        <span class="badge rounded-pill bg-warning text-dark px-3">Để thịt</span>
                                                        break;
                                                    default:
                                                        <span class="badge rounded-pill bg-secondary px-3">@pig.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="Pigs" asp-action="Details" asp-route-id="@pig.Id" class="btn btn-sm btn-outline-info">
                                                    <i class="fas fa-eye"></i> Xem Heo
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-5">
                            <i class="fas fa-box-open fa-4x text-muted mb-3 opacity-50"></i>
                            <h4 class="text-light opacity-75">Chuồng này hiện đang trống</h4>
                            <p class="text-muted">Chưa có heo nào được xếp vào chuồng này.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
