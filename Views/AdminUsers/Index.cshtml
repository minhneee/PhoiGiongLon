@model IEnumerable<SwineBreedingManager.Models.UserViewModel>

@{
    ViewData["Title"] = "Quản Lý Tài Khoản";
}

<div class="glass-card mb-4 p-4 animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 text-light fw-bold mb-0">
                <i class="fas fa-users-cog me-2 text-info"></i>Quản Lý Tài Khoản
            </h1>
            <p class="text-light opacity-75 mb-0">Quản lý danh sách người dùng và phân quyền hệ thống</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary glass-btn-primary px-4 py-2">
                <i class="fas fa-user-plus me-2"></i>Thêm Tài Khoản Mới
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table glass-table">
            <thead>
                <tr>
                    <th>Email / Tên Đăng Nhập</th>
                    <th>Quyền Hạn</th>
                    <th class="text-end">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="animate-row">
                        <td class="fw-bold">
                            <div class="d-flex align-items-center">
                                <div class="avatar-sm me-3 bg-info rounded-circle d-flex align-items-center justify-content-center">
                                    <i class="fas fa-user text-white"></i>
                                </div>
                                @item.Email
                            </div>
                        </td>
                        <td>
                            @if (item.Role == "CHỦ TRẠI")
                            {
                                <span class="badge bg-danger rounded-pill px-3">@item.Role</span>
                            }
                            else if (item.Role == "QUẢN LÝ")
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3">@item.Role</span>
                            }
                            else
                            {
                                <span class="badge bg-info rounded-pill px-3">@item.Role</span>
                            }
                        </td>
                        <td class="text-end">
                            <div class="btn-group">
                                <a asp-action="Permissions" asp-route-userId="@item.Id" class="btn btn-sm btn-outline-info border-0" title="Phân quyền cá nhân">
                                    <i class="fas fa-shield-alt"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light border-0" title="Chỉnh sửa">
                                    <i class="fas fa-edit"></i>
                                </a>
                                @if (item.Email != User.Identity?.Name)
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirmDelete(event, this);">
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(e, form) {
            e.preventDefault();
            Swal.fire({
                title: 'Xác nhận xóa tài khoản?',
                text: "Dữ liệu người dùng sẽ bị xóa vĩnh viễn và không thể khôi phục!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy',
                background: 'rgba(30, 40, 70, 0.95)',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
            return false;
        }
    </script>
}
