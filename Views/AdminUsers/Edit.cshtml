@model SwineBreedingManager.Models.UserViewModel

@{
    ViewData["Title"] = "Chỉnh Sửa Tài Khoản";
}

<div class="glass-card mb-4 p-4 animate-fade-in" style="max-width: 600px; margin: 0 auto;">
    <div class="mb-4">
        <h1 class="display-6 text-light fw-bold mb-0">
            <i class="fas fa-user-edit me-2 text-info"></i>Chỉnh Sửa Tài Khoản
        </h1>
        <p class="text-light opacity-75 mb-0">Cập nhật thông tin hoặc thay đổi quyền hạn người dùng</p>
    </div>

    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger glass-alert"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label text-light fw-bold"></label>
            <input asp-for="Email" class="form-control glass-input" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label text-light fw-bold"></label>
            <select asp-for="Role" class="form-select glass-input">
                <option value="">-- Chọn Quyền Hạn --</option>
                @foreach (var role in ViewBag.Roles)
                {
                    @if (Model.Role == role.ToString())
                    {
                        <option value="@role" selected>@role</option>
                    }
                    else
                    {
                        <option value="@role">@role</option>
                    }
                }
            </select>
            <span asp-validation-for="Role" class="text-danger"></span>
        </div>

        <div class="glass-alert alert alert-info mb-4 border-info">
            <i class="fas fa-info-circle me-2"></i>
            Để trống <strong>Mật khẩu</strong> nếu bạn không muốn thay đổi mật khẩu của người dùng.
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label text-light fw-bold">Mật khẩu mới (Tùy chọn)</label>
            <input asp-for="Password" class="form-control glass-input" type="password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ConfirmPassword" class="form-label text-light fw-bold">Xác nhận mật khẩu mới</label>
            <input asp-for="ConfirmPassword" class="form-control glass-input" type="password" />
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <div class="d-flex justify-content-between align-items-center pt-3 border-top border-secondary">
            <a asp-action="Index" class="btn btn-outline-light px-4">
                <i class="fas fa-arrow-left me-2"></i>Quay Lại
            </a>
            <button type="submit" class="btn btn-primary glass-btn-primary px-5">
                <i class="fas fa-check-circle me-2"></i>Cập Nhật
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
