@model IEnumerable<SwineBreedingManager.Models.Pig>

@{
    ViewData["Title"] = "Quản lý Đàn Heo";
}

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title"><i class="fas fa-piggy-bank me-3"></i>Danh Sách Đàn Heo</h1>
        <a asp-action="Create" class="btn-premium">
            <i class="fas fa-plus me-2"></i>Thêm Heo Mới
        </a>
    </div>

    <!-- Filter Bar -->
    <div class="glass-card shadow mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-light opacity-50"><i class="fas fa-search"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0" placeholder="Tìm tên hoặc số tai..." value="@ViewBag.CurrentSearch" />
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select">
                        <option value="">-- Trạng thái: Đang nuôi --</option>
                        <option value="Sold" selected="@(ViewBag.CurrentStatus?.ToString() == "Sold")">Đã bán</option>
                        <option value="Active" selected="@(ViewBag.CurrentStatus?.ToString() == "Active")">Đang nuôi</option>
                        <option value="Culled" selected="@(ViewBag.CurrentStatus?.ToString() == "Culled")">Loại thải</option>
                        <option value="Dead" selected="@(ViewBag.CurrentStatus?.ToString() == "Dead")">Chết</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="penId" class="form-select">
                        <option value="">-- Tất cả các chuồng --</option>
                        @foreach (var pen in (List<SwineBreedingManager.Models.Pen>)ViewBag.Pens)
                        {
                            <option value="@pen.Id" selected="@(ViewBag.CurrentPenId == pen.Id)">@pen.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <div class="glass-card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover" id="pigsTable">
                    <thead>
                        <tr>
                            <th>Số Tai</th>
                            <th>Tên</th>
                            <th>Giới Tính</th>
                            <th>Ngày Sinh</th>
                            <th>Giống</th>
                            <th>Cân nặng (kg)</th>
                            <th>Tuổi (Ngày)</th>
                            <th>Chuồng</th>
                            <th>Giá Bán</th>
                            <th>Trạng Thái</th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold" style="color: #00d2ff;">@item.TagNumber</td>
                                <td>@(item.Name ?? "---")</td>
                                <td>
                                    @if (item.Gender == SwineBreedingManager.Models.PigGender.Boar)
                                    {
                                        <span class="badge-gender-male"><i class="fas fa-mars me-1"></i>Đực</span>
                                    }
                                    else
                                    {
                                        <span class="badge-gender-female"><i class="fas fa-venus me-1"></i>Nái</span>
                                    }
                                </td>
                                <td>@item.BirthDate.ToString("dd/MM/yyyy")</td>
                                <td>@item.Breed</td>
                                <td class="text-warning fw-bold">@(item.Weight?.ToString("N1") ?? "---") kg</td>
                                <td class="text-info fw-bold">@item.AgeInDays ngày</td>
                                <td>
                                    @if (item.Pen != null)
                                    {
                                        <span class="badge bg-outline-info border border-info text-info"><i class="fas fa-box me-1"></i>@item.Pen.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Chưa xếp</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var statusClass = item.Status switch
                                        {
                                            SwineBreedingManager.Models.PigStatus.Active => "bg-success",
                                            SwineBreedingManager.Models.PigStatus.Sold => "bg-primary",
                                            SwineBreedingManager.Models.PigStatus.Culled => "bg-warning text-dark",
                                            _ => "bg-secondary"
                                        };
                                        var statusName = typeof(SwineBreedingManager.Models.PigStatus)
                                            .GetMember(item.Status.ToString())
                                            .First()
                                            .GetCustomAttributes(typeof(System.ComponentModel.DataAnnotations.DisplayAttribute), false)
                                            .Cast<System.ComponentModel.DataAnnotations.DisplayAttribute>()
                                            .FirstOrDefault()?.Name ?? item.Status.ToString();
                                    }
                                    <span class="badge @statusClass">@statusName</span>
                                    @if (item.Status == SwineBreedingManager.Models.PigStatus.Sold && item.SaleRecord != null)
                                    {
                                        <div class="small fw-bold text-warning mt-1">@item.SaleRecord.Price.ToString("N0") đ</div>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info border-0" title="Chi tiết"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary border-0" title="Sửa"><i class="fas fa-edit"></i></a>
                                        <a asp-controller="Genealogy" asp-action="Tree" asp-route-id="@item.Id" class="btn btn-outline-warning border-0" title="Gia phả"><i class="fas fa-sitemap"></i></a>
                                        <button type="button" class="btn btn-outline-danger border-0" title="Xóa" onclick="confirmDelete(@item.Id, '@item.TagNumber')">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Hidden Delete Form -->
<form id="deleteForm" asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" id="deleteId" name="id" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id, tagNumber) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: `Bạn có chắc chắn muốn xóa heo có số tai: ${tagNumber}? Hành động này không thể hoàn tác!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ff4b2b',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Xóa ngay',
                cancelButtonText: 'Hủy bỏ',
                background: 'rgba(20, 30, 48, 0.95)',
                color: '#fff'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('deleteId').value = id;
                    document.getElementById('deleteForm').submit();
                }
            });
        }
    </script>
}
