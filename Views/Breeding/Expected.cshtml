@model IEnumerable<SwineBreedingManager.Models.BreedingRecord>

@{
    ViewData["Title"] = "Dự Kiến Sinh Nở";
}

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title"><i class="fas fa-calendar-alt me-3"></i>Dự Kiến Sinh Nở</h1>
        <a asp-action="Create" class="btn-premium">
            <i class="fas fa-plus me-2"></i>Đăng Ký Phối Giống
        </a>
    </div>

    <!-- Filter Bar -->
    <div class="glass-card shadow mb-4">
        <div class="card-body">
            <form method="get" asp-action="Expected" class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-light opacity-50"><i class="fas fa-search"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0" placeholder="Tìm số tai Bố hoặc Mẹ..." value="@ViewBag.CurrentSearch" />
                    </div>
                </div>
                <div class="col-md-4">
                    <select name="penId" class="form-select">
                        <option value="">-- Tất cả các chuồng (Vị trí nái) --</option>
                        @foreach (var pen in (List<SwineBreedingManager.Models.Pen>)ViewBag.Pens)
                        {
                            <option value="@pen.Id" selected="@(ViewBag.CurrentPenId == pen.Id)">@pen.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Lọc Dự Kiến</button>
                </div>
            </form>
        </div>
    </div>

    <div class="glass-card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Ngày Phối</th>
                            <th>Ngày Dự Sinh</th>
                            <th>Heo Mẹ (Vị trí)</th>
                            <th>Heo Cha</th>
                            <th>Đếm Ngược</th>
                            <th>Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var daysLeft = item.EstimatedBirthDate.HasValue ? (item.EstimatedBirthDate.Value.Date - DateTime.Now.Date).Days : 0;
                            var countdownClass = daysLeft <= 3 ? "text-danger fw-bold blink" : (daysLeft <= 7 ? "text-warning" : "text-success");
                            
                            <tr>
                                <td>@item.BreedingDate.ToString("dd/MM/yyyy")</td>
                                <td class="fw-bold text-info">@item.EstimatedBirthDate?.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold" style="color: #00d2ff;">@item.Sow?.TagNumber</span>
                                        <span class="small text-white-50">
                                            <i class="fas fa-box me-1"></i>@(item.Sow?.Pen?.Name ?? "Chưa xếp chuồng")
                                        </span>
                                    </div>
                                </td>
                                <td>@item.Boar?.TagNumber</td>
                                <td class="@countdownClass">
                                    @if (daysLeft < 0)
                                    {
                                        <span>Quá hạn @Math.Abs(daysLeft) ngày</span>
                                    }
                                    else if (daysLeft == 0)
                                    {
                                        <span>Hôm nay!</span>
                                    }
                                    else
                                    {
                                        <span>Còn @daysLeft ngày</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Farrow" asp-route-id="@item.Id" class="btn btn-sm btn-success">
                                        <i class="fas fa-baby-carriage me-1"></i>Ghi nhận đẻ
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .blink {
        animation: blinker 1.5s linear infinite;
    }
    @@keyframes blinker {
        50% { opacity: 0.5; }
    }
</style>
