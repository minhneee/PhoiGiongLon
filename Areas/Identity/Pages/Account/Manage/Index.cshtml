@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h3 class="text-light mb-4"><i class="fas fa-id-card-alt me-2"></i>Hồ sơ cá nhân</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-8">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger glass-alert" role="alert"></div>
            
            <div class="mb-3">
                <label asp-for="Username" class="form-label text-light fw-bold">Tên đăng nhập</label>
                <input asp-for="Username" class="form-control glass-input" placeholder="Tên đăng nhập của bạn." disabled />
            </div>

            <div class="mb-4">
                <label asp-for="Input.PhoneNumber" class="form-label text-light fw-bold">Số điện thoại</label>
                <input asp-for="Input.PhoneNumber" class="form-control glass-input" placeholder="Nhập số điện thoại của bạn."/>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-primary glass-btn-primary px-5 py-2">
                <i class="fas fa-save me-2"></i>Lưu thay đổi
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
