@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}
<ul class="nav nav-pills flex-column gap-2">
    <li class="nav-item">
        <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext) glass-nav-pill" id="profile" asp-page="./Index">
            <i class="fas fa-id-card me-2"></i>Hồ sơ cá nhân
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext) glass-nav-pill" id="change-password" asp-page="./ChangePassword">
            <i class="fas fa-key me-2"></i>Mật khẩu
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @ManageNavPages.PersonalDataNavClass(ViewContext) glass-nav-pill" id="personal-data" asp-page="./PersonalData">
            <i class="fas fa-database me-2"></i>Dữ liệu cá nhân
        </a>
    </li>
</ul>
