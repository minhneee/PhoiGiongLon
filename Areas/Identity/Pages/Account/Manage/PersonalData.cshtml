@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Personal Data";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3 class="text-light mb-4"><i class="fas fa-database me-2"></i>Dữ liệu cá nhân</h3>

<div class="row">
    <div class="col-md-8">
        <p class="text-light opacity-75">Tài khoản của bạn chứa dữ liệu cá nhân mà bạn đã cung cấp cho chúng tôi. Trang này cho phép bạn tải xuống hoặc xóa dữ liệu đó.</p>
        <div class="glass-alert alert alert-warning border-warning mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Việc xóa dữ liệu này sẽ xóa vĩnh viễn tài khoản của bạn và không thể khôi phục được.</strong>
        </div>
        
        <div class="d-flex gap-3">
            <form id="download-data" asp-page="DownloadPersonalData" method="post">
                <button class="btn btn-outline-info glass-btn-info px-4" type="submit">
                    <i class="fas fa-download me-2"></i>Tải xuống dữ liệu
                </button>
            </form>
            <a id="delete" asp-page="DeletePersonalData" class="btn btn-danger glass-btn-danger px-4">
                <i class="fas fa-user-slash me-2"></i>Xóa tài khoản
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
