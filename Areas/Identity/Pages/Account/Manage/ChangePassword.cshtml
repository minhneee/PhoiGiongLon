@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h3 class="text-light mb-4"><i class="fas fa-key me-2"></i>Đổi mật khẩu</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
    <div class="col-md-8">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger glass-alert" role="alert"></div>
            
            <div class="mb-3">
                <label asp-for="Input.OldPassword" class="form-label text-light fw-bold">Mật khẩu hiện tại</label>
                <input asp-for="Input.OldPassword" class="form-control glass-input" autocomplete="current-password" aria-required="true" placeholder="Nhập mật khẩu hiện tại." />
                <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.NewPassword" class="form-label text-light fw-bold">Mật khẩu mới</label>
                <input asp-for="Input.NewPassword" class="form-control glass-input" autocomplete="new-password" aria-required="true" placeholder="Nhập mật khẩu mới." />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label text-light fw-bold">Xác nhận mật khẩu mới</label>
                <input asp-for="Input.ConfirmPassword" class="form-control glass-input" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu mới."/>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary glass-btn-primary px-5 py-2">
                <i class="fas fa-check-circle me-2"></i>Cập nhật mật khẩu
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
